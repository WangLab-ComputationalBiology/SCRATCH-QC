process {
    executor = 'awsbatch'
    errorStrategy = 'retry'
    maxRetries = 2
}

params.igenomes_base = 's3://btc-refdata/scratch/'

params {
    
    // illumina iGenomes reference file paths
    genomes {
        'GRCh38' {
            gex = "${params.igenomes_base}/refdata-gex-GRCh38-2024-A"
            vdj = "${params.igenomes_base}/refdata-cellranger-vdj-GRCh38-alts-ensembl-7.1.0"
        }
        'GRCm39' {
            gex = "${params.igenomes_base}/refdata-gex-GRCm39-2024-A"
            vdj = "${params.igenomes_base}/refdata-cellranger-vdj-GRCm38-alts-ensembl-7.0.0"
        }
    }
}

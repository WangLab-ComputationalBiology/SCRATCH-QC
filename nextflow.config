/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default config options for all compute environments
----------------------------------------------------------------------------------------
*/

nextflow.enable.moduleBinaries = true

params {

    // Pipeline parameters
    samplesheet                 = "${baseDir}/assets/test_demux_sample_table.csv"
    meta_data                   = "${baseDir}/assets/test_meta_data.csv"

    genome                      = "GRCh38" // options: GRCh38 and GRCm39
    outdir                      = "${baseDir}/results"
    project_name                = "GBM_DFCI1_CSF"
    modality                    = "GEX"

    // -------------------------------------------------------------------------
    // Alignment mode — set exactly one of the three options below to true.
    //
    //  multi = true   Hashtag-multiplexed samples. Runs cellranger multi with
    //                 native CITE-seq demultiplexing. Samplesheet columns:
    //                   sample_id, multi_config
    //                 multi_config is an absolute path to a cellranger multi
    //                 CSV (contains GEX + CITE library paths + hashtag
    //                 sample assignments). See assets/test_multi_sample_table.csv
    //
    //  demux = true   Pooled FASTQs with auto barcode detection from I1 index.
    //                 Samplesheet columns: run_id, r1, r2, i1, i2, modality
    //
    //  (both false)   Standard mode. Pre-demultiplexed FASTQs, one row per
    //                 sample. Samplesheet columns: sample, fastq_1, fastq_2, modality
    // -------------------------------------------------------------------------
    multi                       = false
    demux                       = false

    // Auto-demux tuning parameters (only used when demux = true)
    demux_n_detect              = 50000  // reads sampled from I1 for barcode detection
    demux_min_freq              = 0.01   // min fraction of sampled reads to call a sample (1%)
    demux_mismatches            = 1      // mismatches tolerated when assigning reads to a barcode

    // Quarto notebooks
    notebook_quality            = "${baseDir}/modules/local/seurat/quality/notebook_seurat_qc.qmd"
    notebook_summarize          = "${baseDir}/modules/local/helper/summarize/notebook_quality_table_report.qmd"
    notebook_merge              = "${baseDir}/modules/local/seurat/merge/notebook_seurat_merge.qmd"
    notebook_scdblfinder        = "${baseDir}/modules/local/scdblfinder/notebook_scdblfinder.qmd"

    notebook_normalize          = "${baseDir}/modules/local/seurat/normalization/notebook_dimensionality_reduction.qmd"
    notebook_clustering         = "${baseDir}/modules/local/seurat/cluster/notebook_seurat_clustering.qmd"
    
    // Cellbender
    expected_cells              = 5000
    total_droplets              = 15000
    fpr                         = 0.01
    epochs                      = 150
    skip_cellbender             = true

    // QC parameters
    input_gex_matrices_path     = "${baseDir}/data/SCRATCH_ALIGN:CELLRANGER_COUNT/*/outs/*"
    input_exp_table             = "${baseDir}/data/pipeline_info/samplesheet.valid.csv"

    thr_estimate_n_cells        = 300
    thr_mean_reads_per_cells    = 25000
    thr_median_genes_per_cell   = 900
    thr_median_umi_per_cell     = 1000
    thr_n_feature_rna_min       = 300
    thr_n_feature_rna_max       = 7500
    thr_percent_mito            = 25
    thr_n_observed_cells        = 300

    // Doublets
    skip_scdblfinder            = false

    // Normalization parameters
    input_merged_object         = "${baseDir}/data/SCRATCH_QC:SEURAT_MERGE/*_merged_object.RDS"

    thr_n_features              = 2000
    thr_n_dimensions            = 100
    
    // Clustering parameters
    input_integration_dimension = "auto"
    input_group_plot            = "patient_id;timepoint"
    thr_resolution              = 0.5
    thr_proportion              = 0.25

    // Dataflow parameters
    // igenomes_base  = 'gs://btc-refdata/scRNA/refData'
    igenomes_base  = "${baseDir}"



     // Quarto parameters
    page_config    = "${baseDir}/assets/template/_quarto.yml"
    logotype       = "${baseDir}/assets/template/SCRATCH.png"
    template       = "${baseDir}/assets/template/*"

    // Max resource options
    max_cpus                = 24
    max_memory              = '128.GB'
    max_time                = '240.h'

}


process {
    containerOptions = {
        workflow.containerEngine == 'docker'
            ? '-u root:root -e USERID=$UID -e XDG_CACHE_HOME=tmp/quarto_cache_home -e XDG_DATA_HOME=tmp/quarto_data_home -e QUARTO_PRINT_STACK=true'
            : workflow.containerEngine == 'singularity'
                ? '--env USERID=$UID --env XDG_CACHE_HOME=tmp/quarto_cache_home --env XDG_DATA_HOME=tmp/quarto_data_home --env QUARTO_PRINT_STACK=true'
                : ''
    }
    stageInMode = 'symlink'
}

// Load nf-core custom profiles from different Institutions
profiles {

    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        docker.fixOwnership    = true
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "${env('HOME')}/singularity_cache"
        docker.enabled         = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }

    test      { includeConfig 'conf/test.config' }
    seadragon { includeConfig 'conf/institution.config' }

}

// Load modules.config for DSL2 module specific options
includeConfig 'conf/modules.config'

// Load base.config by default for all pipelines
includeConfig 'conf/base.config'

// Load igenomes.config
includeConfig 'conf/igenomes.config'

